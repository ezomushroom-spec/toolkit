{
  "manifest_version": 3,
  "name": "Pixiv Tag Collector",
  "version": "0.1.0",
  "description": "Collect tags from a few Pixiv artwork pages opened from the current listing page.",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.pixiv.net/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Pixiv Tag Collector",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.pixiv.net/*"
      ],
      "js": [
        "list-page.js",
        "work-page.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
