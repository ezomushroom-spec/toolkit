<Window
    x:Class="MosaicRemake.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Mosaic Remake WinUI">

    <Grid Background="#FF12161D">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Padding="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,0,10">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="推論モデル" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="SelectModelButton" Grid.Column="1" Content="モデル選択" />
                    </Grid>
                    <Border x:Name="ModelDropBorder" AllowDrop="True" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="12" Padding="14" MinHeight="72">
                        <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text=".pt モデルをここへドロップ" HorizontalAlignment="Center" />
                            <TextBlock Text="または参照ボタンで選択" Foreground="{StaticResource TextSubtleBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="ModelPathText" Text="既定モデルを使用します。" Foreground="{StaticResource TextSubtleBrush}" TextWrapping="Wrap" MaxLines="2" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,0,10">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="入力フォルダ" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="SelectInputButton" Grid.Column="1" Content="入力選択" />
                    </Grid>
                    <Border x:Name="InputDropBorder" AllowDrop="True" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" MinHeight="72">
                        <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="フォルダや画像ファイルをここへドロップ" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="画像ファイルの場合は親フォルダを採用" Foreground="{StaticResource TextSubtleBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="InputPathText" Text="未選択" Foreground="{StaticResource TextSubtleBrush}" TextWrapping="Wrap" MaxLines="2" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,0,10">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="出力フォルダ" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="SelectOutputButton" Grid.Column="1" Content="出力選択" />
                    </Grid>
                    <Border x:Name="OutputDropBorder" AllowDrop="True" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" MinHeight="72">
                        <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="出力先フォルダをここへドロップ" HorizontalAlignment="Center" />
                            <TextBlock Text="将来は安全確認と空フォルダ案内を追加" Foreground="{StaticResource TextSubtleBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="OutputPathText" Text="未選択" Foreground="{StaticResource TextSubtleBrush}" TextWrapping="Wrap" MaxLines="2" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="加工パラメータ" FontSize="17" FontWeight="SemiBold" />

                    <Grid Grid.Row="1" ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="種類" VerticalAlignment="Center" />
                        <ComboBox x:Name="MaskTypeComboBox" Grid.Row="0" Grid.Column="1" MinWidth="0">
                            <ComboBoxItem Content="ピクセルモザイク" Tag="pixel" />
                            <ComboBoxItem Content="ぼかし (ブラー)" Tag="blur" />
                            <ComboBoxItem Content="黒塗り" Tag="black" />
                            <ComboBoxItem Content="白塗り" Tag="white" />
                        </ComboBox>

                        <TextBlock Grid.Row="1" Text="形状" VerticalAlignment="Center" />
                        <ComboBox x:Name="ShapeTypeComboBox" Grid.Row="1" Grid.Column="1" MinWidth="0">
                            <ComboBoxItem Content="矩形 (ボックス)" Tag="box" />
                            <ComboBoxItem Content="形状に沿う (精密)" Tag="mask" />
                        </ComboBox>

                        <TextBlock Grid.Row="2" Text="認識解像度" VerticalAlignment="Center" />
                        <ComboBox x:Name="ImageSizeComboBox" Grid.Row="2" Grid.Column="1" MinWidth="0">
                            <ComboBoxItem Content="640" Tag="640" />
                            <ComboBoxItem Content="960" Tag="960" />
                            <ComboBoxItem Content="1280" Tag="1280" />
                            <ComboBoxItem Content="1600" Tag="1600" />
                        </ComboBox>

                        <TextBlock Grid.Row="3" Text="フィルタ強度" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2">
                            <Slider x:Name="StrengthSlider" Minimum="1" Maximum="100" StepFrequency="1" />
                            <TextBlock x:Name="StrengthValueText" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" />
                        </StackPanel>

                        <TextBlock Grid.Row="4" Text="範囲拡張(px)" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="4" Grid.Column="1" Spacing="2">
                            <Slider x:Name="MarginSlider" Minimum="0" Maximum="100" StepFrequency="1" />
                            <TextBlock x:Name="MarginValueText" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <CheckBox Grid.Row="2" x:Name="ShowBoxesCheckBox" Content="検出領域を表示する" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Padding="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,0,14">
                <StackPanel Spacing="8">
                    <TextBlock Text="プレビュー" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusText" Text="入力フォルダを選び、レビュー表示で最初の画像の preview を生成します。" Foreground="{StaticResource TextSubtleBrush}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="PreviousImageButton" Content="前へ" />
                        <TextBlock x:Name="ImagePositionText" VerticalAlignment="Center" Foreground="{StaticResource TextSubtleBrush}" Text="画像 0 / 0" />
                        <Button x:Name="NextImageButton" Content="次へ" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14">
                <Grid RowSpacing="12" Padding="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="190" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Image x:Name="PreviewImage" Stretch="Uniform" />
                            <TextBlock x:Name="PreviewPlaceholderText" Text="プレビュー領域" Foreground="{StaticResource TextSubtleBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" />
                        </Grid>

                        <Border Grid.Column="1" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="検出領域" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Text="大プレビューを見ながら対象部位ごとに ON/OFF と感度を指定" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" TextWrapping="Wrap" />
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnSpacing="8" MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="46" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="PussyCheckBox" Content="女性器" VerticalAlignment="Center" />
                                            <Slider x:Name="PussyConfSlider" Grid.Column="1" Minimum="1" Maximum="100" StepFrequency="1" VerticalAlignment="Center" />
                                            <TextBlock x:Name="PussyConfValueText" Grid.Column="2" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        </Grid>

                                        <Grid ColumnSpacing="8" MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="46" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="PenisCheckBox" Content="男性器" VerticalAlignment="Center" />
                                            <Slider x:Name="PenisConfSlider" Grid.Column="1" Minimum="1" Maximum="100" StepFrequency="1" VerticalAlignment="Center" />
                                            <TextBlock x:Name="PenisConfValueText" Grid.Column="2" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        </Grid>

                                        <Grid ColumnSpacing="8" MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="46" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="TesticlesCheckBox" Content="睾丸" VerticalAlignment="Center" />
                                            <Slider x:Name="TesticlesConfSlider" Grid.Column="1" Minimum="1" Maximum="100" StepFrequency="1" VerticalAlignment="Center" />
                                            <TextBlock x:Name="TesticlesConfValueText" Grid.Column="2" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        </Grid>

                                        <Grid ColumnSpacing="8" MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="46" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="AnusCheckBox" Content="肛門" VerticalAlignment="Center" />
                                            <Slider x:Name="AnusConfSlider" Grid.Column="1" Minimum="1" Maximum="100" StepFrequency="1" VerticalAlignment="Center" />
                                            <TextBlock x:Name="AnusConfValueText" Grid.Column="2" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        </Grid>

                                        <Grid ColumnSpacing="8" MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="46" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="NipplesCheckBox" Content="乳首" VerticalAlignment="Center" />
                                            <Slider x:Name="NipplesConfSlider" Grid.Column="1" Minimum="1" Maximum="100" StepFrequency="1" VerticalAlignment="Center" />
                                            <TextBlock x:Name="NipplesConfValueText" Grid.Column="2" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        </Grid>

                                        <Grid ColumnSpacing="8" MinHeight="34">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="46" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="BreastCheckBox" Content="胸" VerticalAlignment="Center" />
                                            <Slider x:Name="BreastConfSlider" Grid.Column="1" Minimum="1" Maximum="100" StepFrequency="1" VerticalAlignment="Center" />
                                            <TextBlock x:Name="BreastConfValueText" Grid.Column="2" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="画像一覧" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="横スクロールで連続確認" Foreground="{StaticResource TextSubtleBrush}" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                            <ListView
                                Grid.Row="1"
                                x:Name="ImageListView"
                                SelectionMode="Single"
                                IsItemClickEnabled="True"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollMode="Disabled"
                                ScrollViewer.HorizontalScrollBarVisibility="Visible"
                                ScrollViewer.HorizontalScrollMode="Enabled">
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsStackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,14,0,0">
                <Button x:Name="ReviewButton" Content="レビュー表示" />
                <Button x:Name="BatchButton" Content="一括処理" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
