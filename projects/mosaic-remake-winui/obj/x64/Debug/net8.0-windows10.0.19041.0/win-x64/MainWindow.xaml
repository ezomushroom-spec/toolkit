<Window
    x:Class="MosaicRemake.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Mosaic Remake WinUI">

    <Grid Background="#FF12161D">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14" Padding="16">
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="推論モデル" FontSize="18" FontWeight="SemiBold" />
                        <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="12" Padding="18" MinHeight="92">
                            <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text=".pt モデルをここへドロップ" HorizontalAlignment="Center" />
                                <TextBlock Text="または参照ボタンで選択" Foreground="{StaticResource TextSubtleBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Button x:ConnectionId='7' x:Name="SelectModelButton" Content="モデルを選択" HorizontalAlignment="Right" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="入力フォルダ" FontSize="18" FontWeight="SemiBold" />
                        <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18" MinHeight="92">
                            <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="フォルダや画像ファイルをここへドロップ" HorizontalAlignment="Center" TextAlignment="Center" />
                                <TextBlock Text="画像ファイルの場合は親フォルダを採用" Foreground="{StaticResource TextSubtleBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Button x:ConnectionId='6' x:Name="SelectInputButton" Content="入力を選択" HorizontalAlignment="Right" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="出力フォルダ" FontSize="18" FontWeight="SemiBold" />
                        <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18" MinHeight="92">
                            <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="出力先フォルダをここへドロップ" HorizontalAlignment="Center" />
                                <TextBlock Text="将来は安全確認と空フォルダ案内を追加" Foreground="{StaticResource TextSubtleBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Button x:ConnectionId='5' x:Name="SelectOutputButton" Content="出力を選択" HorizontalAlignment="Right" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="加工パラメータ" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="WinUI 側では、ここに種類・形状・強度・範囲拡張・対象部位などを順次移行します。" TextWrapping="Wrap" Foreground="{StaticResource TextSubtleBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1" Padding="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,0,14">
                <StackPanel Spacing="8">
                    <TextBlock Text="プレビュー" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:ConnectionId='4' x:Name="StatusText" Text="現段階では WinUI シェルのみ。次段で Python core 連携を追加します。" Foreground="{StaticResource TextSubtleBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14">
                <Grid>
                    <TextBlock Text="プレビュー領域" Foreground="{StaticResource TextSubtleBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,14,0,0">
                <Button x:ConnectionId='2' x:Name="ReviewButton" Content="レビュー表示" />
                <Button x:ConnectionId='3' x:Name="BatchButton" Content="一括処理" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

